{
  "name": "trustface-desktop",
  "version": "1.4.7",
  "description": "TrustFace Desktop — Facebook Multi-Account Manager with Marketplace Automation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5176 && electron .\"",
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "rebuild": "node-gyp rebuild --target=35.7.5 --arch=arm64 --dist-url=https://electronjs.org/headers --directory=node_modules/better-sqlite3 --build-from-source",
    "postinstall": "npm run rebuild",
    "build": "vite build && electron-builder",
    "pack": "vite build && electron-builder --dir"
  },
  "author": "TrustMind",
  "license": "UNLICENSED",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.1",
    "better-sqlite3": "^11.9.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.577.0",
    "node-machine-id": "^1.1.12",
    "playwright-core": "^1.52.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "uuid": "^11.1.0"
  },
  "build": {
    "appId": "com.trustface.desktop",
    "productName": "TrustFace Desktop",
    "files": [
      "main.js",
      "preload.js",
      ".env",
      "dist/**/*",
      "src/db/**/*",
      "src/browser/**/*",
      "src/auth/**/*",
      "src/payments/**/*",
      "src/extensions/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "artifactName": "TrustFace-Desktop-${version}-${arch}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "artifactName": "TrustFace-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "danteod99",
      "repo": "trustface-releases"
    }
  }
}
